# Earnings Copilot Backend - Environment Variables

# SEC EDGAR API (Required - Free)
SEC_USER_AGENT=EarningsCopilot contact@earningscopilot.com

# Modal API for GLM-5 (Required for AI reports)
MODAL_API_KEY=modalresearch_xxx

# Financial Modeling Prep (Optional - for transcripts)
FMP_API_KEY=

# Database (Railway sets this automatically)
DATABASE_URL=

# ChromaDB Path (Railway uses /tmp)
CHROMA_PATH=/tmp/chroma_db

# Clerk (for backend auth verification)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
